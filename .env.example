# Copy to .env.local and fill in your values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_from_dashboard
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_from_dashboard

MICROSOFT_CLIENT_ID=your_azure_app_registration_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# Azure OpenAI (preferred) — classic resource: Keys and Endpoint in Azure Portal
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01
#
# Azure AI Foundry (OpenAI-compatible): use full SDK baseURL (…/openai/v1), or host-only …services.ai.azure.com (we append /openai/v1).
# AZURE_OPENAI_ENDPOINT=https://your-foundry.services.ai.azure.com/openai/v1
# Or project scope: https://your-foundry.services.ai.azure.com/api/projects/your-project/openai/v1
# Optional full chat URL (same JSON body as SDK chat.completions):
# AZURE_OPENAI_CHAT_COMPLETIONS_URL=https://your-foundry.services.ai.azure.com/openai/v1/chat/completions
# AZURE_OPENAI_DEPLOYMENT=gpt-5.1
# Foundry /openai/v1/chat/completions: leave api-version off unless your portal requires it (then use only this, not AZURE_OPENAI_API_VERSION):
# AZURE_OPENAI_FOUNDRY_API_VERSION=
# Classic hub still uses:
# AZURE_OPENAI_API_VERSION=2024-02-01
#
# If the gateway expects Bearer instead of api-key: AZURE_OPENAI_AUTH_HEADER=Bearer
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# OpenAI fallback (used if Azure vars above are not set)
OPENAI_API_KEY=

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_PRO_PRICE_ID=price_your_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Your App <noreply@yourdomain.com>

# Required for poll email links: signed token so we know who opened the link when not logged in
POLL_LINK_SECRET=your_long_random_secret_string

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Used to encrypt refresh tokens in the database
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-string

# Optional: for cron jobs (e.g. poll digest, calendar sync)
CRON_SECRET=your_cron_secret_if_using_vercel_cron
